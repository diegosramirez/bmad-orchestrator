# ─── Runtime ────────────────────────────────────────────────────────────────
# Cloud Run sets PORT automatically (default 8080). Override locally if needed.
PORT=8080

# ─── Slack ──────────────────────────────────────────────────────────────────
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=xoxb-...

# ─── GitHub Actions dispatch (used by Slack slash command path) ─────────────
# NOTE: the Slack handler uses bare GITHUB_REPO/GITHUB_TOKEN; the Jira/Forge
# handlers use the BMAD_-prefixed variants below.
GITHUB_REPO=owner/repo
GITHUB_TOKEN=ghp_...
DEFAULT_TARGET_REPO=owner/target-repo
DEFAULT_TEAM_ID=SAM1

# ─── BMAD GitHub dispatch (Jira + Forge paths) ──────────────────────────────
BMAD_GITHUB_REPO=owner/repo
BMAD_GITHUB_TOKEN=ghp_...
BMAD_GITHUB_BASE_BRANCH=main
BMAD_GITHUB_OWNER=owner

# ─── Jira webhook secrets ───────────────────────────────────────────────────
# Optional: if set, inbound requests must carry header X-BMAD-Jira-Secret
BMAD_JIRA_WEBHOOK_SECRET=
# Required for /workflow/* (Forge panels); either of these works
BMAD_FORGE_WEBHOOK_SECRET=
BMAD_DISCOVERY_WEBHOOK_SECRET=

# ─── Jira custom field IDs ──────────────────────────────────────────────────
JIRA_TARGET_REPO_CUSTOM_FIELD_ID=customfield_10112
JIRA_BRANCH_CUSTOM_FIELD_ID=customfield_10145
