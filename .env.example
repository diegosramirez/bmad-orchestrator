# ─── Anthropic ────────────────────────────────────────────────────────────────
BMAD_ANTHROPIC_API_KEY=sk-ant-...
BMAD_MODEL_NAME=claude-sonnet-4-6
# BMAD_MODEL_PROVIDER=anthropic   # default: anthropic
# BMAD_TEMPERATURE=0.0            # default: 0.0 (range: 0.0–1.0)

# ─── Jira ─────────────────────────────────────────────────────────────────────
BMAD_JIRA_BASE_URL=https://yourorg.atlassian.net
BMAD_JIRA_USERNAME=you@yourorg.com
BMAD_JIRA_API_TOKEN=ATATT...
BMAD_JIRA_PROJECT_KEY=PUG

# ─── GitHub ───────────────────────────────────────────────────────────────────
BMAD_GITHUB_REPO=digistore24/ds24-growth
# Branch of the orchestrator repo used as workflow_dispatch `ref` (webhook server only).
BMAD_GITHUB_BASE_BRANCH=main
# BMAD_GITHUB_TOKEN=ghp_...   # PAT with workflow scope (GitHub Actions dispatch API)

# ─── FastAPI webhook (Forge AI Actions: Discovery + Epic Architect) ───────────
# Preferred: BMAD_FORGE_WEBHOOK_SECRET. Forge sends header X-BMAD-Forge-Secret.
# Fallback: BMAD_DISCOVERY_WEBHOOK_SECRET (same header value).
# BMAD_FORGE_WEBHOOK_SECRET=generate-a-long-random-string
# BMAD_DISCOVERY_WEBHOOK_SECRET=generate-a-long-random-string

# ─── Git identity ─────────────────────────────────────────────────────────────
# BMAD_GIT_AUTHOR_NAME=BMAD Orchestrator
# BMAD_GIT_AUTHOR_EMAIL=bmad@noreply.local

# ─── Orchestrator ─────────────────────────────────────────────────────────────
BMAD_DRY_RUN=false
# BMAD_MAX_REVIEW_LOOPS=3
# BMAD_CHECKPOINT_DB_PATH=~/.bmad/checkpoints.db
# BMAD_BMAD_INSTALL_DIR=.claude
# BMAD_BMAD_ROOT=_bmad   # Root dir for BMAD workflows (create-epics-and-stories, correct-course, create-story)

# ─── Slack (optional) ────────────────────────────────────────────────────────
# BMAD_SLACK_NOTIFY=false
# BMAD_SLACK_BOT_TOKEN=xoxb-...   # Bot User OAuth Token (from Slack app settings)
# BMAD_SLACK_CHANNEL=#bmad-notifications

# ─── Dummy/Local mode (file-backed services, no external API calls) ──────────
# BMAD_DUMMY_JIRA=false
# BMAD_DUMMY_GITHUB=false
# BMAD_DUMMY_DATA_DIR=.bmad/dummy
