# ─── Anthropic ────────────────────────────────────────────────────────────────
BMAD_ANTHROPIC_API_KEY=sk-ant-...
BMAD_MODEL_NAME=claude-sonnet-4-6
# BMAD_MODEL_PROVIDER=anthropic   # default: anthropic
# BMAD_TEMPERATURE=0.0            # default: 0.0 (range: 0.0–1.0)

# ─── Jira ─────────────────────────────────────────────────────────────────────
BMAD_JIRA_BASE_URL=https://yourorg.atlassian.net
BMAD_JIRA_USERNAME=you@yourorg.com
BMAD_JIRA_API_TOKEN=ATATT...
BMAD_JIRA_PROJECT_KEY=PUG
# Jira custom field IDs (per Cloud site). Defaults: Digistore/target repo, BMAD branch.
# BMAD_JIRA_TARGET_REPO_CUSTOM_FIELD_ID=customfield_10112
# BMAD_JIRA_BRANCH_CUSTOM_FIELD_ID=customfield_10145
# Checklists for Jira | Free — Checklist Text (Paragraph) field id
# BMAD_JIRA_CHECKLIST_TEXT_CUSTOM_FIELD_ID=customfield_10046
# Mermaid diagrams in Jira descriptions → PNG + attachment (off | kroki | mmdc)
# BMAD_MERMAID_RENDERER=off
# BMAD_JIRA_MEDIA_COLLECTION=
# BMAD_KROKI_URL=https://kroki.io
# BMAD_MMDC_PATH=mmdc
# mmdc PNG size (defaults: 1600×1200, scale 1.5)
# BMAD_MERMAID_MMDC_WIDTH=1600
# BMAD_MERMAID_MMDC_HEIGHT=1200
# BMAD_MERMAID_MMDC_SCALE=1.5

# ─── GitHub ───────────────────────────────────────────────────────────────────
BMAD_GITHUB_REPO=digistore24/ds24-growth
# Branch of the orchestrator repo used as workflow_dispatch `ref` (GitHub Actions / Vercel worker).
BMAD_GITHUB_BASE_BRANCH=main
# BMAD_GITHUB_TOKEN=ghp_...   # PAT: workflow (dispatch) + read access to Actions (list runs; duplicate-run guard)

# ─── Forge + slack-worker (Vercel): panel dispatch + Jira webhooks ─────────────
# Deploy `slack-worker/` and set these on the Vercel project (and matching Forge variables).
# Forge panels: BMAD_FORGE_WEBHOOK_URL = origin only (e.g. https://your-app.vercel.app).
# Preferred secret names: BMAD_FORGE_WEBHOOK_SECRET (Forge header X-BMAD-Forge-Secret).
# Fallback: BMAD_DISCOVERY_WEBHOOK_SECRET (same value).
# BMAD_FORGE_WEBHOOK_SECRET=generate-a-long-random-string
# BMAD_DISCOVERY_WEBHOOK_SECRET=generate-a-long-random-string

# ─── Git identity ─────────────────────────────────────────────────────────────
# BMAD_GIT_AUTHOR_NAME=BMAD Orchestrator
# BMAD_GIT_AUTHOR_EMAIL=bmad@noreply.local

# ─── Orchestrator ─────────────────────────────────────────────────────────────
BMAD_DRY_RUN=false
# BMAD_MAX_REVIEW_LOOPS=3
# BMAD_CHECKPOINT_DB_PATH=~/.bmad/checkpoints.db
# BMAD_BMAD_INSTALL_DIR=.claude
# BMAD_BMAD_ROOT=_bmad   # Root dir for BMAD workflows (create-epics-and-stories, correct-course, create-story)

# ─── Slack (optional) ────────────────────────────────────────────────────────
# BMAD_SLACK_NOTIFY=false
# BMAD_SLACK_BOT_TOKEN=xoxb-...   # Bot User OAuth Token (from Slack app settings)
# BMAD_SLACK_CHANNEL=#bmad-notifications

# ─── Dummy/Local mode (file-backed services, no external API calls) ──────────
# BMAD_DUMMY_JIRA=false
# BMAD_DUMMY_GITHUB=false
# BMAD_DUMMY_DATA_DIR=.bmad/dummy

# ─── Figma MCP (LOCAL DEV ONLY) ───────────────────────────────────────────────
# Gives the developer agent access to the official Figma Dev Mode MCP server
# over SSE. Requires Figma desktop running with Dev Mode on the same machine.
# Does NOT work in GitHub Actions, Cloud Run, or any headless environment.
# BMAD_FIGMA_MCP_ENABLED=false
# BMAD_FIGMA_MCP_URL=http://127.0.0.1:3845/sse
